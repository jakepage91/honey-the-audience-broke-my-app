{
  "target": {
    "path": {
      "deployment": "vote-api"
    },
    "namespace": "conference-app"
  },
  "feature": {
    "network": {
      "incoming": {
        "mode": "steal",
        "http_filter": {
          "header_filter": "baggage:\\s*[^\\n]*\\bmirrord=e2e\\b"
        }
      },
      "outgoing": true,
      "dns": true
    },
    "env": {
      "include": "DATABASE_URL;REDIS_URL;POSTGRES_USER;POSTGRES_PASSWORD;POSTGRES_DB;DB_POOL_SIZE;DB_MAX_OVERFLOW;APP_VERSION;CONFERENCE"
    },
    "fs": {
      "mode": "read"
    }
  },
  "operator": false,
  "kubeconfig": "~/.kube/config"
}
